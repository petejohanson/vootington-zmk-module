		    , <&key_physical_attrs 100 100 1075 300 0 0 0>
		    , <&key_physical_attrs 100 100 1175 300 0 0 0>
		
		    , <&key_physical_attrs 125 100 000  400 0 0 0>
		    , <&key_physical_attrs 100 100 125  400 0 0 0>
		    , <&key_physical_attrs 125 100 225  400 0 0 0>
		    , <&key_physical_attrs 275 100 350  400 0 0 0>
		    , <&key_physical_attrs 225 100 625  400 0 0 0>
		    , <&key_physical_attrs 125 100 850  400 0 0 0>
		    , <&key_physical_attrs 100 100 975  400 0 0 0>
		    , <&key_physical_attrs 100 100 1075 400 0 0 0>
		    , <&key_physical_attrs 100 100 1175 400 0 0 0>
		    ;
	};

	jetvan_layout: jetvan_layout {
		compatible = "zmk,physical-layout";
		display-name = "JetVan";

		status = "disabled";
		
		// transform = <&jetvan_transform>;
		// kscan = <&kscan>;
		
		keys
		    = <&key_physical_attrs 100 100 050  000 0 0 0>
		    , <&key_physical_attrs 100 100 150  000 0 0 0>
		    , <&key_physical_attrs 100 100 250  000 0 0 0>
		    , <&key_physical_attrs 100 100 350  000 0 0 0>
		    , <&key_physical_attrs 100 100 450  000 0 0 0>
		    , <&key_physical_attrs 100 100 550  000 0 0 0>

		    , <&key_physical_attrs 100 100 000  100 0 0 0>
		    , <&key_physical_attrs 100 100 100  100 0 0 0>
		    , <&key_physical_attrs 100 100 200  100 0 0 0>
		    , <&key_physical_attrs 100 100 300  100 0 0 0>
		    , <&key_physical_attrs 100 100 400  100 0 0 0>
