/dts-v1/;
#include <st/g0/stm32g0b1Xb.dtsi>
#include <st/g0/stm32g0b1c(b-c-e)tx-pinctrl.dtsi>

#include <zephyr/dt-bindings/dt-util.h>
#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/clock/stm32_common_clocks.h>
#include <dt-bindings/led/led.h>

#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
	model = "Cavlin Vootington";
	compatible = "calvin,vootington";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &code_partition;
		zephyr,boot-mode = &retention0;
		/* zmk,underglow = &led_strip; */
	};

	mux: mux {
		compatible = "zmk,gpio-mux";
		
		select-gpios
		    = <&gpiob 10 GPIO_ACTIVE_HIGH>
		    , <&gpiob 2 GPIO_ACTIVE_HIGH>
		    , <&gpiob 1 GPIO_ACTIVE_HIGH>
		    ;
		
		gpio-controller;
		ngpios = <16>;
		#gpio-cells = <2>;
	};

	matrix: matrix {
		compatible = "zmk,kscan-he-matrix";
		active-polling-interval-ms = <0>;

		select-gpios
			= <&mux 0 0>
			, <&mux 1 0>
			, <&mux 2 0>
			, <&mux 3 0>
			, <&mux 4 0>
			, <&mux 5 0>
			, <&mux 6 0>
			, <&mux 7 0>
			;
		io-channels =          <&adc1 2 &adc1 3     &adc1 4 &adc1 5      &adc1 6     &adc1 7     &adc1 8>;
		channel-select-masks = <0>,     <(BIT(4))>, <0>,    <(BIT(0))>,  <(BIT(2))>, <0>,        <(BIT(3) + BIT(5))>;
		high-threshold-noise-mult = <6>;

		thunderdome_ex {
			compatible="zmk,analog-matrix-thunderdome-keys";
			pos-a = <0 4>;
			pos-b = <2 4>;
			tie-mode = "both";
		};

		#if 0
			precalib-avg-highs = <
		2969
