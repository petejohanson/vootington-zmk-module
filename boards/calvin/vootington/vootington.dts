	split_transform: split_transform {
		compatible = "zmk,matrix-transform";
		rows = <5>;
		columns = <15>;
		
		map = <
		 RC(6,1)  RC(6,2) RC(6,0) RC(6,4) RC(6,6) RC(6,7)
		 RC(0,1)  RC(0,6) RC(2,1) RC(2,6) RC(3,1) RC(3,6) RC(4,0) RC(4,6) RC(4,7) RC(5,1) RC(5,6) RC(1,7)
		 RC(0,2)  RC(0,4) RC(2,2) RC(2,4) RC(3,2) RC(3,4) RC(4,1) RC(4,4) RC(5,2) RC(5,4) RC(1,2) RC(1,6)
		 RC(0,3)  RC(0,5) RC(2,3) RC(2,5) RC(3,3) RC(3,5) RC(4,3) RC(4,5) RC(5,3) RC(5,5) RC(1,0) RC(1,3)
		 RC(0,0)  RC(0,7) RC(2,0)        RC(2,7)          RC(3,7)         RC(5,0) RC(5,7) RC(1,1) RC(1,5)
		>;
	};


	split_jetvan_layout: split_jetvan_layout {
		compatible = "zmk,physical-layout";
		display-name = "Split JetVan";
		
		transform = <&split_transform>;
		kscan = <&matrix>;
		
		keys
		    = <&key_physical_attrs 100 100 050  000 0 0 0>
		    , <&key_physical_attrs 100 100 150  000 0 0 0>
		    , <&key_physical_attrs 100 100 250  000 0 0 0>
		    , <&key_physical_attrs 100 100 350  000 0 0 0>
		    , <&key_physical_attrs 100 100 450  000 0 0 0>
		    , <&key_physical_attrs 100 100 550  000 0 0 0>

		    , <&key_physical_attrs 100 100 000  100 0 0 0>
		    , <&key_physical_attrs 100 100 100  100 0 0 0>
		    , <&key_physical_attrs 100 100 200  100 0 0 0>
		    , <&key_physical_attrs 100 100 300  100 0 0 0>
		    , <&key_physical_attrs 100 100 400  100 0 0 0>
		    , <&key_physical_attrs 100 100 500  100 0 0 0>
